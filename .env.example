# =====================================================================
# KRYZEN Telegram Business Platform - Environment Configuration
# Copy to .env and fill with your real values
# =====================================================================

# ---------- Application ----------
APP_NAME="KRYZEN Telegram Business"
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_TIMEZONE=UTC
APP_BASE_URL=https://your-domain.com

# ---------- Bot ----------
BOT_TOKEN=123456:ABC-DEF...replace_me
BOT_WEBHOOK_SECRET=kryzen_webhook_secret_change_me
BOT_WEBHOOK_URL=https://your-domain.com/webhook
BOT_ADMIN_CHAT_ID=000000000
SUPER_ADMIN_ID=000000000

# ---------- Database (PostgreSQL) ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=kryzen
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=kryzen_business
DATABASE_URL=postgresql+asyncpg://kryzen:change_this_strong_password@postgres:5432/kryzen_business

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password
REDIS_DB=0
REDIS_URL=redis://:change_this_redis_password@redis:6379/0

# ---------- JWT / Security ----------
JWT_SECRET=please_change_to_long_random_string_min_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=2592000
ENCRYPTION_KEY=fernet_key_base64_32_bytes_xxxxxxxxxxxxxxxx

# ---------- GroqCloud (AI) ----------
GROQ_API_KEY=gsk_replace_with_your_groq_api_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT=30
GROQ_MAX_RETRIES=2

# ---------- Telegram Business ----------
BUSINESS_API_ENABLED=true
BUSINESS_BOT_USERNAME=YourBusinessBot
SUPPORTED_BUSINESS_FEATURES=auto_reply,ai_reply,message_archive,media_archive

# ---------- Premium ----------
PREMIUM_DEFAULT_DAYS=30
PREMIUM_TRIAL_DAYS=7
FREE_ARCHIVE_DAYS=7
PREMIUM_ARCHIVE_DAYS=unlimited

# ---------- Rate Limit ----------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=10000
BROADCAST_RATE=25

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# ---------- Webhook / Mini App ----------
MINI_APP_URL=https://your-domain.com/miniapp
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# ---------- Backup ----------
BACKUP_ENABLED=true
BACKUP_PATH=/app/backups
BACKUP_RETENTION_DAYS=14
